rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - role: string (required, 'user' or 'admin')
    //   - balance: number (optional)
    //
    // Collection: services
    // Document ID: serviceId
    // Fields:
    //   - id: string (required)
    //   - platform: string (required)
    //   - name: string (required)
    //   - price: number (required)
    //   - min: string (optional)
    //   - max: string (optional)
    //   - imageUrl: string (optional)
    //
    // Collection: orders
    // Document ID: orderId
    // Fields:
    //   - id: string (required)
    //   - uid: string (required)
    //   - serviceId: string (required)
    //   - serviceName: string (required)
    //   - quantity: number (required)
    //   - totalPrice: number (required)
    //   - status: string (required, 'pending', 'completed', 'cancelled')
    //   - createdAt: string (required, ISO 8601)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          request.auth.token.email == "smubasshir532@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    function isValidService(data) {
      return data.keys().hasAll(['id', 'platform', 'name', 'price']) &&
             data.id is string &&
             data.platform is string &&
             data.name is string &&
             data.price is number;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'uid', 'serviceId', 'serviceName', 'quantity', 'totalPrice', 'status', 'createdAt']) &&
             data.id is string &&
             data.uid is string &&
             data.serviceId is string &&
             data.serviceName is string &&
             data.quantity is number &&
             data.totalPrice is number &&
             data.status in ['pending', 'completed', 'cancelled'] &&
             data.createdAt is string;
    }

    function isValidTicket(data) {
      return data.keys().hasAll(['id', 'uid', 'email', 'subject', 'message', 'status', 'createdAt']) &&
             data.id is string &&
             data.uid is string &&
             data.email is string &&
             data.subject is string &&
             data.message is string &&
             data.status in ['open', 'replied', 'closed'] &&
             data.createdAt is string;
    }

    function isValidPaymentRequest(data) {
      return data.keys().hasAll(['id', 'uid', 'email', 'amount', 'method', 'screenshot', 'status', 'createdAt']) &&
             data.id is string &&
             data.uid is string &&
             data.email is string &&
             data.amount is number &&
             data.method in ['paypal', 'crypto'] &&
             data.screenshot is string &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidService(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && request.auth.uid == request.resource.data.uid;
      allow update: if isAdmin() && isValidOrder(request.resource.data);
    }

    match /tickets/{ticketId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if isAuthenticated() && isValidTicket(request.resource.data) && request.auth.uid == request.resource.data.uid;
      allow update: if isAuthenticated() && (isAdmin() || (request.auth.uid == resource.data.uid && request.resource.data.uid == resource.data.uid));
    }

    match /payment_requests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if isAuthenticated() && isValidPaymentRequest(request.resource.data) && request.auth.uid == request.resource.data.uid;
      allow update: if isAdmin() && isValidPaymentRequest(request.resource.data);
    }
  }
}
